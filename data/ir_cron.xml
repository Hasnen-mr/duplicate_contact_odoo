<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">

    <record id="ir_cron_duplicate_contact_scan" model="ir.cron">
        <field name="name">Duplicate Contact: Automatic Scan</field>
        <field name="model_id" ref="model_duplicate_contact_pair"/>
        <field name="state">code</field>
        <field name="code">model.cron_detect_duplicates()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
