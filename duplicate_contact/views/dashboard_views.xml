<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_duplicate_contact_dashboard_form" model="ir.ui.view">
        <field name="name">duplicate.contact.dashboard.form</field>
        <field name="model">duplicate.contact.dashboard</field>
        <field name="arch" type="xml">
            <form string="Duplicate Contact Manager" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>Smart Duplicate Contact Manager</h1>
                        <p class="text-muted">
                            Find, review, and merge duplicate contacts across your database.
                        </p>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-2 col-6 mb-3 text-center">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted">Total Contacts</div>
                                <field name="total_contacts" class="fs-2 fw-bold"/>
                            </div>
                        </div>
                        <div class="col-md-2 col-6 mb-3 text-center">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted">Duplicates Found</div>
                                <field name="duplicates_found" class="fs-2 fw-bold text-danger"/>
                            </div>
                        </div>
                        <div class="col-md-2 col-6 mb-3 text-center">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted">Need Review</div>
                                <field name="need_review" class="fs-2 fw-bold text-warning"/>
                            </div>
                        </div>
                        <div class="col-md-2 col-6 mb-3 text-center">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted">Merged</div>
                                <field name="merged_count" class="fs-2 fw-bold text-success"/>
                            </div>
                        </div>
                        <div class="col-md-2 col-6 mb-3 text-center">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted">Ignored</div>
                                <field name="ignored_count" class="fs-2 fw-bold"/>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button name="action_run_scan" type="object" string="Run Scan Now" class="btn btn-primary"/>
                        <button name="action_open_duplicates" type="object" string="Review Duplicates" class="btn btn-secondary"/>
                        <button name="action_open_review" type="object" string="Need Review" class="btn btn-secondary"/>
                        <button name="action_open_merged" type="object" string="Merge History" class="btn btn-link"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_duplicate_contact_dashboard" model="ir.actions.server">
        <field name="name">Dashboard</field>
        <field name="model_id" ref="model_duplicate_contact_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
